{
  "manifest_version": 3,
  "name": "Minimal URL Parameter Stripper",
  "version": "1.0.0",
  "description": "Strips tracking parameters cleanly before requests hit the network.",
  "permissions": [
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.instagram.com/*",
    "*://*.youtu.be/*"
  ],
  "declarative_net_request": {
    "rule_resources": [{
      "id": "ruleset_1",
      "enabled": true,
      "path": "rules.json"
    }]
  }
}